# OpenAI
OPENAI_API_KEY=sk-...

# App
ENVIRONMENT=development
LOG_LEVEL=debug

# DB (docker-compose defaults work out of the box)
POSTGRES_HOST=pnt-postgres
POSTGRES_PORT=5432
POSTGRES_DB=pnt_mes
POSTGRES_USER=pnt
POSTGRES_PASSWORD=pnt

# Redis
REDIS_HOST=pnt-redis
REDIS_PORT=6379

# Simulator
SIMULATOR_INTERVAL_MS=500
ANOMALY_INJECT_PROB=0.015
